# Entorno
PORT=3001
NODE_ENV=production

# Base de datos (MongoDB Atlas en producción)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/strongheart?retryWrites=true&w=majority

# JWT — genera un secreto fuerte con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<min-32-chars-random-secret>
JWT_EXPIRE=7d

# CORS — URL del frontend desplegado (sin barra final)
# Múltiples orígenes: https://tudominio.com,https://www.tudominio.com
CORS_ORIGIN=https://tudominio.com
